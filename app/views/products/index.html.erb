<h1 class="text-3xl font-bold mb-8">Nos photos de chatons</h1>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
  <% @products.each do |product| %>
    <div class="bg-white rounded-lg shadow-md overflow-hidden transition-transform hover:scale-105">
      <%= link_to product_path(product) do %>
        <img src="<%= product.image_url %>" alt="<%= product.title %>" class="w-full h-48 object-cover">
      <% end %>
      <div class="p-4">
        <h3 class="text-xl font-semibold mb-2"><%= product.title %></h3>
        <p class="text-gray-500 mb-4"><%= truncate(product.description, length: 80) %></p>
        <div class="flex justify-between items-center">
          <span class="text-pink-600 font-bold"><%= number_to_currency(product.price, unit: "€") %></span>
          <%= link_to "Voir détails", product_path(product), class: "px-3 py-1 bg-pink-100 text-pink-600 rounded-md hover:bg-pink-200" %>
        </div>
      </div>
    </div>
  <% end %>
</div>