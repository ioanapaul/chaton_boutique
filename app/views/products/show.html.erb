<div class="bg-white rounded-lg shadow-md overflow-hidden">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="p-6">
      <img src="<%= @product.image_url %>" alt="<%= @product.title %>" class="w-full h-auto rounded-lg">
    </div>
    
    <div class="p-6">
      <h1 class="text-3xl font-bold mb-4"><%= @product.title %></h1>
      
      <div class="text-2xl text-pink-600 font-bold mb-6">
        <%= number_to_currency(@product.price, unit: "€") %>
      </div>
      
      <div class="mb-6">
        <h2 class="text-xl font-semibold mb-2">Description</h2>
        <p class="text-gray-700"><%= @product.description %></p>
      </div>
      
      <% if user_signed_in? %>
        <%= form_with url: cart_items_path, method: :post, class: "mb-6" do |f| %>
          <%= f.hidden_field :product_id, value: @product.id %>
          
          <div class="flex items-center mb-4">
            <label for="quantity" class="mr-4 font-semibold">Quantité:</label>
            <%= f.number_field :quantity, value: 1, min: 1, class: "border rounded-md px-3 py-2 w-20" %>
          </div>
          
          <%= f.submit "Ajouter au panier", class: "w-full bg-pink-600 text-white py-3 rounded-md font-semibold hover:bg-pink-700" %>
        <% end %>
      <% else %>
        <div class="bg-gray-100 p-4 rounded-md mb-6">
          <p class="text-gray-700 mb-2">Connectez-vous pour ajouter ce produit à votre panier.</p>
          <div class="flex space-x-2">
            <%= link_to "Se connecter", login_path, class: "px-4 py-2 bg-pink-600 text-white rounded-md hover:bg-pink-700" %>
            <%= link_to "S'inscrire", signup_path, class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-md hover:bg-gray-300" %>
          </div>
        </div>
      <% end %>
      
      <div class="border-t pt-6">
        <h2 class="text-xl font-semibold mb-2">Informations supplémentaires</h2>
        <ul class="space-y-2 text-gray-700">
          <li><strong>Format:</strong> JPEG haute résolution</li>
          <li><strong>Livraison:</strong> Par email après achat</li>
        </ul>
      </div>
    </div>
  </div>
</div>
