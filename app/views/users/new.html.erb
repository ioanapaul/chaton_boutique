<div class="max-w-md mx-auto bg-white rounded-lg shadow-md overflow-hidden">
  <div class="px-6 py-8">
    <h1 class="text-2xl font-bold text-center mb-6">Créer un compte</h1>
    
    <%= form_with model: @user, url: users_path do |f| %>
      <% if @user.errors.any? %>
        <div class="bg-red-100 border-red-400 text-red-700 px-4 py-3 rounded border mb-4">
          <ul class="list-disc pl-5">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      
      <div class="mb-4">
        <%= f.label :email, class: "block text-gray-700 font-semibold mb-2" %>
        <%= f.email_field :email, class: "w-full px-4 py-2 border rounded-md focus:outline-none focus:border-pink-500", placeholder: "votre@email.com" %>
      </div>
      
      <div class="mb-4">
        <%= f.label :password, "Mot de passe", class: "block text-gray-700 font-semibold mb-2" %>
        <%= f.password_field :password, class: "w-full px-4 py-2 border rounded-md focus:outline-none focus:border-pink-500", placeholder: "••••••••" %>
      </div>
      
      <div class="mb-6">
        <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "block text-gray-700 font-semibold mb-2" %>
        <%= f.password_field :password_confirmation, class: "w-full px-4 py-2 border rounded-md focus:outline-none focus:border-pink-500", placeholder: "••••••••" %>
      </div>
      
      <%= f.submit "S'inscrire", class: "w-full bg-pink-600 text-white py-2 rounded-md font-semibold hover:bg-pink-700" %>
    <% end %>
    
    <div class="mt-6 text-center">
      <p class="text-gray-600">Vous avez déjà un compte? <%= link_to "Se connecter", login_path, class: "text-pink-600 hover:underline" %></p>
    </div>
  </div>
</div>
