    <h1 class="text-4xl md:text-5xl font-bold mb-4">Des photos de chatons adorables</h1>
    <p class="text-xl mb-8">Trouvez votre dose quotidienne de mignonnerie avec nos photos de chatons de haute qualité</p>
    <%= link_to "Voir nos photos", products_path, class: "px-6 py-3 bg-white text-pink-600 rounded-md font-semibold hover:bg-gray-100" %>
  </div>
</section>

