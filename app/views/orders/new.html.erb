<h1 class="text-3xl font-bold mb-8">Finaliser votre commande</h1>

<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  <div>
    <div class="bg-white rounded-lg shadow-md overflow-hidden mb-6">
      <div class="px-6 py-4 bg-gray-50 border-b">
        <h2 class="font-semibold text-lg">Récapitulatif de votre panier</h2>
      </div>
      <div class="p-6">
        <table class="w-full">
          <thead>
            <tr>
              <th class="text-left text-gray-500 text-sm uppercase pb-2">Produit</th>
              <th class="text-right text-gray-500 text-sm uppercase pb-2">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @cart.cart_items.includes(:product).each do |item| %>
              <tr>
                <td class="py-4">
                  <div class="flex items-center">
                    <img class="h-10 w-10 rounded-full object-cover mr-3" src="<%= item.product.image_url %>" alt="<%= item.product.title %>">
                    <div>
                      <div class="font-medium text-gray-900"><%= item.product.title %></div>
                      <div class="text-sm text-gray-500">Quantité: <%= item.quantity %></div>
                    </div>
                  </div>
                </td>
                <td class="py-4 text-right font-medium text-gray-900">
                  <%= number_to_currency(item.product.price * item.quantity, unit: "€") %>
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr>
              <td class="pt-6 text-right font-semibold">Total:</td>
              <td class="pt-6 text-right font-semibold text-pink-600 text-xl">
                <%= number_to_currency(@cart.total_price, unit: "€") %>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>
  
  <div>
    <div class="bg-white rounded-lg shadow-md overflow-hidden mb-6">
      <div class="px-6 py-4 bg-gray-50 border-b">
        <h2 class="font-semibold text-lg">Méthode de paiement</h2>
      </div>
      <div class="p-6">
        <p class="text-gray-700 mb-6">Les photos seront envoyées à votre adresse email après confirmation du paiement.</p>
        
        <%= form_with url: orders_path, method: :post, id: "payment-form" do |f| %>
          <div class="mb-6">
            <h3 class="font-semibold mb-2">Paiement sécurisé</h3>
            <p class="text-sm text-gray-500 mb-4">Vous allez être redirigé vers notre partenaire Stripe pour effectuer le paiement en toute sécurité.</p>
            
            <div class="bg-gray-50 p-4 rounded-md border mb-4">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                </div>
                <div class="ml-3">
                  <p class="text-sm font-medium text-gray-700">Paiement sécurisé par Stripe</p>
                  <p class="text-xs text-gray-500">Vos données de paiement sont chiffrées et sécurisées.</p>
                </div>
              </div>
            </div>
          </div>
          
          <%= f.submit "Procéder au paiement", class: "w-full bg-pink-600 text-white py-3 rounded-md font-semibold hover:bg-pink-700" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
